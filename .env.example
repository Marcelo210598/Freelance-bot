# ── Banco de Dados (Neon PostgreSQL) ───────────────────
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxxx.us-east-2.aws.neon.tech/freelance_bot?sslmode=require

# ── Segurança ──────────────────────────────────────────
# Token compartilhado entre Railway API e Vercel (BFF)
ADMIN_TOKEN=troque-por-um-token-secreto-longo

# ── Telegram ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:ABCDefGhIJKlmNoPQRsTUVwxyz
TELEGRAM_CHAT_ID=-1001234567890

# ── GitHub ────────────────────────────────────────────
GITHUB_USERNAME=seu-usuario-github
# Token opcional; aumenta rate limit de 60 → 5000 req/h
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxx

# ── Perfil curado (opcional) ──────────────────────────
# URL pública do seu site com JSON de perfil
PROFILE_URL=https://seusite.vercel.app/api/profile.json

# ── Configurações padrão (substituíveis pelo dashboard) ─
DIARIA_BASE=100.0            # R$ por dia útil
THRESHOLD_SCORE=0.45         # score mínimo para alertar (0–1)
FREQ_MINUTOS=45              # frequência de coleta
GITHUB_REFRESH_HORAS=8       # reprocessamento do perfil

# ── Railway (usado para monitoramento externo opcional) ─
RAILWAY_ENVIRONMENT=production

# ── Ambiente ──────────────────────────────────────────
ENV=development              # development | production
LOG_LEVEL=INFO
